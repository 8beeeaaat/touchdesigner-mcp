{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/integration-test-guard.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking integration-test coverage"
          }
        ]
      }
    ]
  }
}
