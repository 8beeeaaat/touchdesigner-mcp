{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"outDir": "./dist",
		"moduleResolution": "bundler",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"declaration": true
	},
	"include": ["src/**/*", "tests"],
	"exclude": ["node_modules","src/gen/**/*.ts","src/ui-app/**/*","**/*/*.test.ts"]
}
